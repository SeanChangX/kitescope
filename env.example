# KiteScope - copy to .env and fill values

# Backend
# SECRET_KEY: JWT signing. Required in production. Unset => "change-me-dev" (insecure).
# Generate: openssl rand -hex 32
SECRET_KEY=
DATABASE_URL=sqlite:///./data/kitescope.db
# INTERNAL_SECRET: backend-vision internal API auth. Unset => no check (anyone can call /api/internal/*).
# Generate: openssl rand -hex 32 (use same value in backend and vision)
INTERNAL_SECRET=

# Optional: LINE (fallback if not set in admin UI)
#   LINE_CHANNEL_ID=
#   LINE_CHANNEL_SECRET=
#   LINE_CHANNEL_ACCESS_TOKEN=

# Optional: Telegram (fallback if not set in admin UI)
#   TELEGRAM_BOT_TOKEN=

# Optional: public app URL for "View live" link in notifications (fallback if not set in Admin → Settings)
# PUBLIC_APP_URL=

# Vision
GO2RTC_BASE_URL=http://go2rtc:1984

# Frontend: VITE_API_URL is set in compose/Dockerfile. Optional overrides (dev: env; prod: build args):
# VITE_PREVIEW_INTERVAL_MS=3000
# VITE_COUNTS_INTERVAL_MS=3000
# VITE_PREVIEW_STAGGER_MS=500
