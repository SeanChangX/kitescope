# KiteScope - copy to .env and fill values

# Backend
DATABASE_URL=sqlite:///./data/kitescope.db

# Optional: LINE (fallback if not set in admin UI)
#   LINE_CHANNEL_ID=
#   LINE_CHANNEL_SECRET=
#   LINE_CHANNEL_ACCESS_TOKEN=

# Optional: Telegram (fallback if not set in admin UI)
#   TELEGRAM_BOT_TOKEN=

# Optional: public app URL. For security (CORS + LINE redirect). Also used for "View live" in notifications.
#   PUBLIC_APP_URL=

# Vision
GO2RTC_BASE_URL=http://go2rtc:1984

# Frontend: VITE_API_URL is set in compose/Dockerfile. Optional overrides (dev: env; prod: build args):
# VITE_PREVIEW_INTERVAL_MS=5000
# VITE_PREVIEW_STAGGER_MS=500
